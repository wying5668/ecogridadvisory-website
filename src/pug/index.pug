doctype html
html(lang='en')
    head
        meta(charset='utf-8')
        meta(name='viewport', content='width=device-width, initial-scale=1, shrink-to-fit=no')
        meta(name='description', content='EcoGrid Advisory provides specialist power system, grid connection, BESS, renewable generation and large load advisory services across the Australian National Electricity Market.')
        meta(name='author', content='EcoGrid Advisory')
        title EcoGrid Advisory | Power System & Grid Connection Specialists

        link(rel='icon', type='image/x-icon', href='assets/favicon.ico')
        script(src='https://use.fontawesome.com/releases/v6.3.0/js/all.js', crossorigin='anonymous')
        link(href='https://fonts.googleapis.com/css?family=Montserrat:400,700', rel='stylesheet', type='text/css')
        link(href='https://fonts.googleapis.com/css?family=Roboto+Slab:400,100,300,700', rel='stylesheet', type='text/css')
        link(href='css/styles.css', rel='stylesheet')

    body#page-top
        nav#mainNav.navbar.navbar-expand-lg.navbar-dark.fixed-top
            .container
                a.navbar-brand(href='#page-top') EcoGrid Advisory
                button.navbar-toggler(type='button', data-bs-toggle='collapse', data-bs-target='#navbarResponsive', aria-controls='navbarResponsive', aria-expanded='false', aria-label='Toggle navigation')
                    | Menu
                    i.fas.fa-bars.ms-1
                #navbarResponsive.collapse.navbar-collapse
                    ul.navbar-nav.text-uppercase.ms-auto.py-4.py-lg-0
                        li.nav-item
                            a.nav-link(href='#services') Services
                        li.nav-item
                            a.nav-link(href='#expertise') Expertise
                        li.nav-item
                            a.nav-link(href='#about') About
                        li.nav-item
                            a.nav-link(href='#contact') Contact

        header.masthead
            .container
                .masthead-subheading Power System & Grid Connection Advisory
                .masthead-heading.text-uppercase Enabling complex energy connections in the NEM
                a.btn.btn-primary.btn-xl.text-uppercase(href='#contact') Discuss Your Project

        section#services.page-section
            .container
                .text-center
                    h2.section-heading.text-uppercase Services
                    h3.section-subheading.text-muted Specialist technical and regulatory advisory for developers, OEMs, investors and energy users.

                .row.text-center
                    .col-md-4
                        span.fa-stack.fa-4x
                            i.fas.fa-circle.fa-stack-2x.text-primary
                            i.fas.fa-plug.fa-stack-1x.fa-inverse
                        h4.my-3 Grid Connection Strategy
                        p.text-muted
                            | Connection application support, GPS negotiation, access standard review, risk identification, NSP/AEMO engagement and technical strategy from feasibility through to commissioning.

                    .col-md-4
                        span.fa-stack.fa-4x
                            i.fas.fa-circle.fa-stack-2x.text-primary
                            i.fas.fa-battery-full.fa-stack-1x.fa-inverse
                        h4.my-3 BESS & Inverter-Based Resources
                        p.text-muted
                            | Advisory for BESS, solar, wind and hybrid projects, including system strength, EMT model review, stability performance, fault ride-through and inverter control risks.

                    .col-md-4
                        span.fa-stack.fa-4x
                            i.fas.fa-circle.fa-stack-2x.text-primary
                            i.fas.fa-industry.fa-stack-1x.fa-inverse
                        h4.my-3 Large Load Connections
                        p.text-muted
                            | Connection strategy for data centres, hydrogen, electrification and flexible demand projects, including network impact, power quality and operational risk assessment.

        section#expertise.page-section.bg-light
            .container
                .text-center
                    h2.section-heading.text-uppercase Technical Expertise
                    h3.section-subheading.text-muted Practical power system insight for projects facing complex connection and compliance challenges.

                .row
                    .col-lg-4.col-sm-6.mb-4
                        .portfolio-item
                            .portfolio-caption
                                .portfolio-caption-heading System Strength
                                .portfolio-caption-subheading.text-muted
                                    | Assessment strategy, remediation options, inverter interaction risks and system strength charging pathways.

                    .col-lg-4.col-sm-6.mb-4
                        .portfolio-item
                            .portfolio-caption
                                .portfolio-caption-heading EMT & RMS Studies
                                .portfolio-caption-subheading.text-muted
                                    | Review of PSCAD, PSS®E and PowerFactory study scope, model quality, benchmarking and dynamic performance evidence.

                    .col-lg-4.col-sm-6.mb-4
                        .portfolio-item
                            .portfolio-caption
                                .portfolio-caption-heading GPS & NER Compliance
                                .portfolio-caption-subheading.text-muted
                                    | Access standard negotiation, compliance evidence review and practical interpretation of NER technical obligations.

                    .col-lg-4.col-sm-6.mb-4
                        .portfolio-item
                            .portfolio-caption
                                .portfolio-caption-heading BESS Control Performance
                                .portfolio-caption-subheading.text-muted
                                    | Review of GFM/GFL behaviour, FRT, active power recovery, voltage control, damping and control interaction issues.

                    .col-lg-4.col-sm-6.mb-4
                        .portfolio-item
                            .portfolio-caption
                                .portfolio-caption-heading Power Quality
                                .portfolio-caption-subheading.text-muted
                                    | Harmonics, voltage fluctuations, reactive capability, plant control accuracy and compliance risk management.

                    .col-lg-4.col-sm-6.mb-4
                        .portfolio-item
                            .portfolio-caption
                                .portfolio-caption-heading Independent Technical Review
                                .portfolio-caption-subheading.text-muted
                                    | Owner’s engineer support, due diligence, connection risk review and technical challenge of consultant/OEM submissions.

        section#about.page-section
            .container
                .text-center
                    h2.section-heading.text-uppercase About EcoGrid Advisory
                    h3.section-subheading.text-muted Independent, technically rigorous and commercially pragmatic advice for the energy transition.

                .row.justify-content-center
                    .col-lg-10
                        p.text-muted
                            | EcoGrid Advisory Pty Ltd provides specialist technical and regulatory advisory services for renewable generation, battery energy storage systems and large industrial load connections across the Australian National Electricity Market.
                        p.text-muted
                            | We bring deep power system modelling expertise, practical connection experience and a strong understanding of NSP and AEMO expectations. Our work helps clients identify technical risks early, develop credible connection strategies and progress projects through increasingly complex approval pathways.
                        p.text-muted
                            | EcoGrid Advisory supports developers, OEMs, investors, consultants and energy users who need senior-level insight into grid connection, system strength, access standards, plant performance and compliance strategy.

        section.page-section.bg-light
            .container
                .text-center
                    h2.section-heading.text-uppercase Why Clients Engage Us
                    h3.section-subheading.text-muted Senior technical judgement for high-value connection decisions.

                .row.text-center
                    .col-md-3
                        h4.my-3 NEM Expertise
                        p.text-muted
                            | Current, practical understanding of Australian grid connection and compliance requirements.

                    .col-md-3
                        h4.my-3 Technical Depth
                        p.text-muted
                            | Power system modelling, inverter behaviour, system strength and stability insight.

                    .col-md-3
                        h4.my-3 Regulatory Clarity
                        p.text-muted
                            | Clear positioning on access standards, NER obligations and evidence expectations.

                    .col-md-3
                        h4.my-3 Commercial Focus
                        p.text-muted
                            | Advice that supports bankable project outcomes while managing technical risk.

        section#contact.page-section
            .container
                .text-center
                    h2.section-heading.text-uppercase Contact EcoGrid Advisory
                    h3.section-subheading.text-muted Discuss your project, connection challenge or technical review requirement.

                .row.justify-content-center
                    .col-lg-8.text-center
                        p.large.text-muted
                            | For enquiries regarding grid connection strategy, BESS performance, large load connections or independent technical review, please contact EcoGrid Advisory.
                        p
                            a.btn.btn-primary.btn-xl.text-uppercase(href='mailto:info@ecogridadvisory.com.au') Email EcoGrid Advisory
                        p.text-muted
                            | Melbourne, Victoria, Australia

        footer.footer.py-4
            .container
                .row.align-items-center
                    .col-lg-4.text-lg-start
                        | Copyright &copy; EcoGrid Advisory 2026
                    .col-lg-4.my-3.my-lg-0
                    .col-lg-4.text-lg-end
                        a.link-dark.text-decoration-none.me-3(href='#page-top') Back to top

        script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js')
        script(src='js/scripts.js')
